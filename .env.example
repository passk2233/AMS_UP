# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
# Base URL of the AMS backend REST API, including scheme and any path prefix.
# Examples:
#   API_URL=http://10.0.2.2:8080/api        (Android emulator -> local backend)
#   API_URL=https://abc123.ngrok-free.app/api
API_URL=
